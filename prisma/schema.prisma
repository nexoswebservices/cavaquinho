generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress    UserProgress[]
  savedStudos EstudoSalvo[]
}

enum Role {
  admin
  user
}

model UserProgress {
  id          String    @id @default(cuid())
  userId      String
  moduleId    String    @db.VarChar(50)
  lessonId    String    @db.VarChar(50)
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId, lessonId])
  @@index([userId])
}

model Estudo {
  id        String   @id @default(cuid())
  titulo    String
  artista   String
  youtubeId String   @unique
  tom       String
  bpm       Int
  compasso  String   @default("4/4")
  introSecs Float    @default(0)
  tabData   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salvos EstudoSalvo[]

  @@index([artista])
}

model EstudoSalvo {
  id        String   @id @default(cuid())
  userId    String
  estudoId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  estudo Estudo @relation(fields: [estudoId], references: [id], onDelete: Cascade)

  @@unique([userId, estudoId])
  @@index([userId])
}

model PartituraIndex {
  id         String   @id @default(cuid())
  artista    String
  postTitulo String   @db.Text
  postUrl    String   @unique
  createdAt  DateTime @default(now())

  @@index([artista])
}
